{
  "name": "tree-sitter-toolang",
  "version": "0.0.5",
  "description": "Toolang grammar for tree-sitter",
  "license": "MIT",
  "homepage": "https://github.com/openhat-ai/tree-sitter-toolang",
  "bugs": {
    "url": "https://github.com/openhat-ai/tree-sitter-toolang/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openhat-ai/tree-sitter-toolang.git"
  },
  "keywords": [
    "grammar",
    "parser",
    "toolang",
    "tree-sitter",
    "tree-sitter-grammar"
  ],
  "main": "grammar.js",
  "files": [
    "grammar.js",
    "queries/*.scm",
    "src/**",
    "tree-sitter.json",
    "README.md",
    "LICENSE"
  ],
  "tree-sitter": [
    {
      "name": "toolang",
      "scope": "source.toolang",
      "file-types": [
        "too"
      ],
      "highlights": "queries/highlights.scm",
      "injections": "queries/injections.scm",
      "tags": "queries/tags.scm"
    }
  ],
  "scripts": {
    "generate": "tree-sitter generate",
    "test": "tree-sitter test",
    "build:wasm": "tree-sitter build --wasm",
    "parse": "tree-sitter parse",
    "highlight": "tree-sitter highlight",
    "tags": "tree-sitter tags",
    "test:cli": "node scripts/check_cli.mjs",
    "pack:dry-run": "npm pack --dry-run",
    "check": "npm run generate && npm run test && npm run test:cli"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.24.7"
  }
}
