{
  "grammars": [
    {
      "name": "toolang",
      "camelcase": "Toolang",
      "scope": "source.toolang",
      "path": ".",
      "file-types": [
        "t"
      ]
    }
  ],
  "metadata": {
    "version": "0.0.4",
    "license": "MIT",
    "description": "toolang grammar for tree-sitter",
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-toolang"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
