        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "name",
              "content": {
                "type": "SYMBOL",
                "name": "identifier"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": "=>"
                },
                {
                  "type": "FIELD",
                  "name": "output",
                  "content": {
                    "type": "SYMBOL",
                    "name": "identifier"
                  }
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": ":"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "comment"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "newline"
        }
      ]
    },
    "directive_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "indent"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": "no"
                },
                {
                  "type": "CHOICE",
                  "members": [
                    {
                      "type": "FIELD",
                      "name": "target",
                      "content": {
                        "type": "SYMBOL",
                        "name": "line_value"
                      }
                    },
                    {
                      "type": "BLANK"
                    }
                  ]
                }
              ]
            },
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": "with"
                },
                {
                  "type": "FIELD",
                  "name": "target",
                  "content": {
                    "type": "SYMBOL",
                    "name": "line_value"
                  }
                }
              ]
            },
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": "use"
                },
                {
                  "type": "FIELD",
                  "name": "target",
                  "content": {
                    "type": "SYMBOL",
                    "name": "line_value"
                  }
                }
              ]
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "comment"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "newline"
        }
      ]
    },
    "prompt_line": {
      "type": "PREC",
      "value": -1,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "indent"
              },
              {
                "type": "BLANK"
              }
            ]
          },
          {
            "type": "FIELD",
            "name": "text",
            "content": {
              "type": "SYMBOL",
              "name": "text"
            }
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "comment"
              },
              {
                "type": "BLANK"
              }
            ]
          },
          {
            "type": "SYMBOL",
            "name": "newline"
          }
        ]
      }
    },
    "indent": {
      "type": "PATTERN",
      "value": "[ \\t]+"
    },
    "cap_kind": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "skill"
        },
        {
          "type": "STRING",
          "value": "service"
        },
        {
          "type": "STRING",
          "value": "prompt"
        },
        {
          "type": "STRING",
          "value": "psyche"
        }
      ]
    },
    "decl_kind": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "service"
        },
        {
          "type": "STRING",
          "value": "prompt"
        },
        {
          "type": "STRING",
          "value": "psyche"
        },
        {
          "type": "STRING",
          "value": "output"
        },
        {
          "type": "STRING",
          "value": "note"
        }
      ]
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[A-Za-z_][A-Za-z0-9_-]*"
    },
    "reference": {
      "type": "PATTERN",
      "value": "[A-Za-z0-9_./-]+"
    },
    "language": {
      "type": "PATTERN",
      "value": "[A-Za-z0-9_-]+"
    },
    "line_value": {
      "type": "PATTERN",
      "value": "[^\\n#]+"
    },
    "text": {
      "type": "PATTERN",
      "value": "[^\\n#][^\\n]*"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t\\f]"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": []
}
