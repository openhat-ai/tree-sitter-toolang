{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "toolang",
  "word": "identifier",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "comment"
          },
          {
            "type": "SYMBOL",
            "name": "use_statement"
          },
          {
            "type": "SYMBOL",
            "name": "declaration_header"
          },
          {
            "type": "SYMBOL",
            "name": "thunk_header"
          },
          {
            "type": "SYMBOL",
            "name": "directive_line"
          },
          {
            "type": "SYMBOL",
            "name": "fence_delimiter"
          },
          {
            "type": "SYMBOL",
            "name": "prompt_line"
          },
          {
            "type": "SYMBOL",
            "name": "newline"
          }
        ]
      }
    },
    "newline": {
      "type": "PATTERN",
      "value": "\\r?\\n"
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "#"
          },
          {
            "type": "PATTERN",
            "value": "[^\\n]*"
          }
        ]
      }
    },
    "use_statement": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "use"
        },
        {
          "type": "FIELD",
          "name": "kind",
          "content": {
            "type": "SYMBOL",
            "name": "cap_kind"
          }
        },
        {
          "type": "FIELD",
          "name": "reference",
          "content": {
            "type": "SYMBOL",
            "name": "reference"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "comment"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "newline"
        }
      ]
    },
    "declaration_header": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "kind",
          "content": {
            "type": "SYMBOL",
            "name": "decl_kind"
          }
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "STRING",
          "value": ":"
        },
        {
          "type": "FIELD",
          "name": "fence",
          "content": {
            "type": "SYMBOL",
            "name": "fence_delimiter_inline"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "comment"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "newline"
        }
      ]
    },
    "fence_delimiter_inline": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "```"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "language",
              "content": {
                "type": "SYMBOL",
                "name": "language"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "fence_delimiter": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "```"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "language",
              "content": {
                "type": "SYMBOL",
                "name": "language"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "comment"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "newline"
        }
      ]
    },
    "thunk_header": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "thunk"
